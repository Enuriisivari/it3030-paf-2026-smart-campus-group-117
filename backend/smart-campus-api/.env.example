## Backend environment (.env)
## Copy to: backend/smart-campus-api/.env
## Then restart the backend.

# MongoDB (Atlas or local)
MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER_HOST>/smart_campus?retryWrites=true&w=majority

# Google OAuth2 (Web application client)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Frontend URL for OAuth redirect after login
FRONTEND_URL=http://localhost:5173

# App secrets
JWT_SECRET=change-this-to-a-long-random-secret-key-for-production-min-256-bits
QR_HMAC_SECRET=change-qr-hmac-secret

# Optional
JWT_EXPIRATION_MS=86400000
UPLOAD_DIR=uploads
DEV_LOGIN_ENABLED=true
